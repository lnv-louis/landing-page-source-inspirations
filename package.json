{
  "name": "landing-page-source-inspirations",
  "private": true,
  "version": "0.1.0",
  "description": "Deployable landing-page source corpus for Architect page canonicalisation evals.",
  "type": "module",
  "scripts": {
    "generate": "node scripts/generate-corpus.mjs",
    "validate": "tsx scripts/validate-corpus.jsx",
    "build": "npm run generate && npm run validate && vite build",
    "dev": "npm run generate && vite --host 0.0.0.0",
    "deploy": "npm run build && npx wrangler deploy"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.19.2",
    "vite": "^6.0.0",
    "wrangler": "^4.99.0"
  },
  "engines": {
    "node": ">=22"
  }
}
